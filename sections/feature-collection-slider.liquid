<!-- Link Swiper's CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .feat-coll-slider {
    background-color: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
    color: #000;
  }

  .feat-coll-flex {
    display: flex;
    align-items: stretch;
  }

  /* LEFT: 45% */
  .feat-coll-left {
    width: 45%;
    padding-right: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 30px;
    box-sizing: border-box;
  }

  .feat-coll-info h3 {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 8px;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
  }
  .feat-coll-info .price {
    font-size: 16px;
    color: #666;
    margin: 0;
  }

  /* Preview Image (Left Middle) - 200x200 */
  .feat-coll-preview {
    width: 200px;
    height: 200px;
    background: #fff;
    border: 1px solid #eee;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .feat-coll-preview img {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }

  /* THUMB SLIDER (Master) */
  .feat-coll-thumbs-wrap {
    margin-top: auto;
    width: 100%;
    overflow: hidden;
    padding: 10px 0;
  }
  .thumb-master-swiper .swiper-slide {
    height: 100px;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .thumb-master-swiper .swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Highlight based on our custom class */
  .thumb-master-swiper .swiper-slide.show-item {
    box-shadow: inset 0 0 0 3px #F2C94C;
  }

  /* RIGHT: 55% (Fixed High-Quality Image) */
  .feat-coll-right {
    width: 55%;
    height: 600px;
    background: #f7f7f7;
    position: relative;
    overflow: hidden;
  }
  .master-lifestyle-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.5s ease;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .feat-coll-flex { flex-direction: column; }
    .feat-coll-left, .feat-coll-right { width: 100%; padding: 0 15px; }
    .feat-coll-right { height: 400px; order: 1; margin-bottom: 20px; }
    .feat-coll-left { order: 2; gap: 20px; }
    .feat-coll-preview { margin: 0 auto; }
    .feat-coll-info { text-align: center; }
  }
{%- endstyle -%}

{%- assign product_list = section.settings.product_list -%}
{%- assign total = product_list.count | default: 0 -%}

<div class="feat-coll-slider section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if total > 0 -%}
      <div class="feat-coll-flex">
        <!-- LEFT Column -->
        <div class="feat-coll-left">
          <div class="feat-coll-info" id="FcInfo-{{ section.id | replace: '-', '_' }}">
            <h3>&nbsp;</h3>
            <p class="price">&nbsp;</p>
          </div>

          <div class="feat-coll-preview" id="FcPreview-{{ section.id | replace: '-', '_' }}">
            <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Glass Preview" />
          </div>

          <div class="feat-coll-thumbs-wrap">
            <div class="swiper thumb-master-swiper" id="FcMaster-{{ section.id | replace: '-', '_' }}">
              <div class="swiper-wrapper">
                {%- for product in product_list -%}
                  {%- assign glass_img = product.media[0] | default: product.featured_image -%}
                  {%- assign life_img = product.media[1] | default: product.featured_image -%}
                  {%- assign thumb_img = life_img -%}

                  <div class="swiper-slide" 
                    data-real-index="{{ forloop.index0 }}"
                    data-title="{{ product.title | escape }}"
                    data-price="{{ product.price | money }}"
                    data-glass="{{ glass_img | image_url: width: 600 }}"
                    data-lifestyle="{{ life_img | image_url: width: 1200 }}"
                  >
                    {{ thumb_img | image_url: width: 200 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT Column -->
        <div class="feat-coll-right" id="FcRight-{{ section.id | replace: '-', '_' }}">
          <img class="master-lifestyle-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Main View" width="1000" height="600" loading="lazy" />
        </div>
      </div>
    {%- else -%}
      <div class="center">Please select products in the section settings.</div>
    {%- endif -%}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
(function(){
  function init(){
    const sid = '{{ section.id | replace: "-", "_" }}';
    const mEl = document.getElementById('FcMaster-'+sid);
    const iEl = document.getElementById('FcInfo-'+sid);
    const pEl = document.getElementById('FcPreview-'+sid);
    const rEl = document.getElementById('FcRight-'+sid);
    
    if(!mEl) return;

    function selectProduct(ri) {
      if (ri === undefined || ri === null) return;
      
      // 1. Manage Classes on all instances (inc clones)
      mEl.querySelectorAll('.swiper-slide').forEach(sl => sl.classList.remove('show-item'));
      mEl.querySelectorAll('.swiper-slide[data-real-index="' + ri + '"]').forEach(sl => sl.classList.add('show-item'));

      // 2. Extract Data from one of the active instances
      const slide = mEl.querySelector('.swiper-slide[data-real-index="' + ri + '"]');
      if (!slide) return;

      const title = slide.getAttribute('data-title');
      const price = slide.getAttribute('data-price');
      const glass = slide.getAttribute('data-glass');
      const life = slide.getAttribute('data-lifestyle');

      // Update Info
      if(iEl) {
        const h3 = iEl.querySelector('h3');
        const p = iEl.querySelector('.price');
        if(h3) h3.textContent = title || '';
        if(p) p.innerHTML = price || '';
      }

      // Update Preview (Left)
      const gImg = pEl.querySelector('img');
      if(gImg && glass && gImg.src !== glass) {
        gImg.style.opacity = '0';
        setTimeout(() => { 
          gImg.src = glass; 
          gImg.onload = () => gImg.style.opacity = '1';
        }, 150);
      }

      // Update Lifestyle (Right)
      const lImg = rEl.querySelector('img');
      if(lImg && life && lImg.src !== life) {
        lImg.style.opacity = '0';
        setTimeout(() => { 
          lImg.src = life; 
          lImg.onload = () => lImg.style.opacity = '1';
        }, 200);
      }
    }

    var swiper = new Swiper(mEl, {
      slidesPerView: 5,
      spaceBetween: 12,
      loop: false,
      grabCursor: true,
      slideToClickedSlide: true,
      watchSlidesProgress: true,
      breakpoints: {
        320: { slidesPerView: 3 },
        750: { slidesPerView: 5 },
        1200: { slidesPerView: 7 }
      },
      on: {
        init: function() {
          selectProduct(0);
        },
        click: function(s, e) {
          const slide = e.target.closest('.swiper-slide');
          if (slide) {
            const idx = parseInt(slide.getAttribute('data-real-index'));
            if (!isNaN(idx)) {
              selectProduct(idx);
            }
          }
        },
        slideChange: function() {
          // Sync UI when user swipes manually
          if (this.activeIndex !== undefined) {
             const currentSelected = mEl.querySelector('.swiper-slide.show-item');
             const selIdx = currentSelected ? parseInt(currentSelected.getAttribute('data-real-index')) : -1;
             
             // If manual swipe moves the selected item out of view, follow the activeIndex
             const spv = Math.floor(this.params.slidesPerView || 1);
             if (selIdx < this.activeIndex || selIdx >= (this.activeIndex + spv)) {
               selectProduct(this.activeIndex);
             }
          }
        }
      }
    });

    // Handle initial load
    setTimeout(() => {
      if (swiper) selectProduct(0);
    }, 400);
  }

  document.addEventListener('DOMContentLoaded', init);
  if(window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', init);
  }
})();
</script>

{% schema %}
{
  "name": "Feature Coll Slider",
  "tag": "section",
  "class": "section feature-collection-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SEESON LATEST ARRIVALS"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explore our carefully curated collection...</p>"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F2F2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Feature Coll Slider"
    }
  ]
}
{% endschema %}
