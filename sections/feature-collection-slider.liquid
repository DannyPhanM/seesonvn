<!-- Link Swiper's CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .feat-coll-slider {
    background-color: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
    color: #000;
  }

  .feat-coll-flex {
    display: flex;
    align-items: stretch;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 80px;
  }

  .feat-coll-header {
    max-width: var(--page-width);
    margin: 0 auto 40px;
    padding: 0 80px;
  }
  .feat-coll-header h2 {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 10px;
    text-transform: uppercase;
  }
  .feat-coll-header .description {
    font-size: 16px;
    color: #666;
    max-width: 600px;
    line-height: 1.5;
  }

  /* DESKTOP LAYOUT (Default) */
  .feat-coll-left {
    width: 57.657%;
    padding: 32px;
    padding-left: 0;
    padding-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .feat-coll-info-text h3 {
    font-size: 30px;
    font-weight: 600;
    letter-spacing: 0.09px;
    color: #999;
    margin: 0 0 8px;
    text-transform: uppercase;
  }
  .feat-coll-info .price {
    font-size: 30px;
    color: #999;
    font-weight: 600;
    margin-top: 10px;
  }

  .feat-coll-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .feat-coll-info-actions {
    display: flex;
    gap: 15px;
  }
  .feat-coll-info-actions svg {
    width: 38px !important;
    height: 38px !important;
    cursor: pointer;
    stroke: #999;
  }

  .feat-coll-preview {
    width: 250px;
    height: 250px;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .feat-coll-preview img {
    max-width: 90%; max-height: 90%;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }

  .feat-coll-thumbs-wrap {
    margin-top: auto;
    padding-top: 50px;
    width: 100%;
    overflow: hidden;
  }

  .thumb-master-swiper .swiper-slide {
    height: auto;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.6;
    position: relative;
  }
  .thumb-master-swiper .swiper-slide.show-item { opacity: 1; }
  .thumb-master-swiper .swiper-slide img {
    width: 100%; height: 100%;
    object-fit: cover;
    aspect-ratio: 82 / 120;
    display: block;
  }

  /* INDICATORS */
  .feat-coll-thumbs-wrap .swiper-slide::after {
    content: "";
    position: absolute;
    background: #999;
    transition: transform 0.3s ease;
  }

  /* Style Top (25px) */
  .style-top.thumb-master-swiper .swiper-slide { padding-top: 15px; }
  .style-top.thumb-master-swiper .swiper-slide::after {
    top: 3px; left: 50%; width: 25px; height: 2px;
    transform: translateX(-50%) scaleX(0);
  }
  .style-top.thumb-master-swiper .swiper-slide.show-item::after { transform: translateX(-50%) scaleX(1); }

  /* Style Full Top (Was Bottom) */
  .style-bottom.thumb-master-swiper .swiper-slide { padding-top: 15px; }
  .style-bottom.thumb-master-swiper .swiper-slide::after {
    top: 3px; left: 50%; width: 55px; height: 2px;
    transform: translateX(-50%) scaleX(0); transform-origin: left;
  }
  .style-bottom.thumb-master-swiper .swiper-slide.show-item::after { transform: translateX(-50%) scaleX(1); }

  .feat-coll-right {
    width: 42.343%;
    background: transparent;
    position: relative;
    overflow: hidden;
  }
  .master-lifestyle-img {
    width: 100%; height: 100%;
    aspect-ratio: 542 / 710;
    display: block;
    transition: opacity 0.5s ease;
    object-fit: contain;
  }

  /* MOBILE LAYOUT (Design Match) */
  @media screen and (max-width: 749px) {
    .feat-coll-flex {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) 60px; /* Image | Thumbs */
      grid-template-areas:
        "main thumbs"
        "info info";
      gap: 15px;
      padding: 0 15px;
      width: 100%;
      box-sizing: border-box;
    }

    .feat-coll-header {
      padding: 0 15px;
      margin-bottom: 25px;
    }
    .feat-coll-header h2 {
      font-size: 22px;
    }
    .feat-coll-header .description {
      font-size: 14px;
    }

    .feat-coll-left {
      display: contents; /* Allows children to be positions by grid */
    }

    .feat-coll-right {
      grid-area: main;
      width: 100% !important;
      height: auto !important;
      aspect-ratio: 3 / 4;
      background: transparent;
    }

    .feat-coll-thumbs-wrap {
      grid-area: thumbs;
      width: 100% !important;
      height: auto !important;
      align-self: end; /* Push to bottom */
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    .thumb-master-swiper {
      height: 100% !important;
      max-height: 400px; /* Adjust as needed */
    }

    .thumb-master-swiper .swiper-slide {
      padding: 0 !important;
      margin-bottom: 10px;
    }

    .feat-coll-info {
      grid-area: info;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 10px;
      width: 100%;
    }

    .feat-coll-info-text h3 {
      font-size: 16px;
      margin-bottom: 3px;
    }

    .feat-coll-info .price {
      font-size: 14px;
    }

    .feat-coll-preview {
      display: none;
    }

    /* Mobile Active Item Style: Overlay border to ensure visibility */
    .thumb-master-swiper .swiper-slide::after {
      display: none !important;
    }
    .thumb-master-swiper .swiper-slide.show-item::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      border: 1px solid #999;
      z-index: 5;
      pointer-events: none;
    }
  }
{%- endstyle -%}

{%- assign product_list = section.settings.product_list -%}
{%- assign total = product_list.count | default: 0 -%}

<div class="feat-coll-slider section-{{ section.id }}-padding">
  <div class="">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="feat-coll-header">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="description">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if total > 0 -%}
      <div class="feat-coll-flex">
        <!-- LEFT/CONTENT -->
        <div class="feat-coll-left">
          <div class="feat-coll-info" id="FcInfo-{{ section.id | replace: '-', '_' }}">
            <div class="feat-coll-info-text">
              <h3>&nbsp;</h3>
              <p class="price">&nbsp;</p>
            </div>
            <div class="feat-coll-info-actions">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon-bookmark"
              >
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
          </div>

          <div class="feat-coll-preview" id="FcPreview-{{ section.id | replace: '-', '_' }}">
            <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Preview">
          </div>

          <div class="feat-coll-thumbs-wrap">
            <div
              class="swiper thumb-master-swiper style-{{ section.settings.indicator_style }}"
              id="FcMaster-{{ section.id | replace: '-', '_' }}"
            >
              <div class="swiper-wrapper">
                {%- for product in product_list -%}
                  <div
                    class="swiper-slide"
                    data-real-index="{{ forloop.index0 }}"
                    data-title="{{ product.title | escape }}"
                    data-available="{{ product.available }}"
                    data-price="{{ product.price | money }}"
                    data-glass="{{ product.media[0] | image_url: width: 600 }}"
                    data-lifestyle="{{ product.media[1] | image_url: width: 1200 }}"
                  >
                    {{ product.media[1] | image_url: width: 200 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT/MAIN IMAGE -->
        <div class="feat-coll-right" id="FcRight-{{ section.id | replace: '-', '_' }}">
          <img
            class="master-lifestyle-img"
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
            alt="Main View"
            loading="lazy"
          >
        </div>
      </div>
    {%- else -%}
      <div class="center">Please select products in the settings.</div>
    {%- endif -%}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script>
  (function(){
    function init(){
      const sid = '{{ section.id | replace: "-", "_" }}';
      const mEl = document.getElementById('FcMaster-'+sid);
      const iEl = document.getElementById('FcInfo-'+sid);
      const pEl = document.getElementById('FcPreview-'+sid);
      const rEl = document.getElementById('FcRight-'+sid);

      if(!mEl || typeof Swiper === 'undefined') {
        if (!mEl) return;
        setTimeout(init, 100);
        return;
      }

      function selectProduct(ri) {
        const slides = mEl.querySelectorAll('.swiper-slide[data-real-index="' + ri + '"]');
        if(slides.length === 0) return;

        mEl.querySelectorAll('.swiper-slide').forEach(sl => sl.classList.remove('show-item'));
        slides.forEach(sl => sl.classList.add('show-item'));

        const slide = slides[0];
        if(iEl) {
          iEl.querySelector('h3').textContent = slide.getAttribute('data-title');
          const isAvailable = slide.getAttribute('data-available') === 'true';
          iEl.querySelector('.price').innerHTML = isAvailable ? slide.getAttribute('data-price') : '{{ 'products.product.sold_out' | t | default: 'Out of stock' }}';
        }
        if(pEl) {
          const gImg = pEl.querySelector('img');
          const glass = slide.getAttribute('data-glass');
          if(gImg && glass) {
            gImg.style.opacity = '0';
            setTimeout(() => { gImg.src = glass; gImg.onload = () => gImg.style.opacity = '1'; }, 50);
          }
        }
        if(rEl) {
          const lImg = rEl.querySelector('img');
          const life = slide.getAttribute('data-lifestyle');
          if(lImg && life) {
            lImg.style.opacity = '0';
            setTimeout(() => { lImg.src = life; lImg.onload = () => lImg.style.opacity = '1'; }, 100);
          }
        }
      }

      const swiper = new Swiper(mEl, {
        slidesPerView: 4, spaceBetween: 15,
        breakpoints: {
          320: { direction: 'vertical', slidesPerView: 5, spaceBetween: 10 },
          750: { direction: 'horizontal', slidesPerView: 7, spaceBetween: 22 }
        },
        on: {
          init: function() { selectProduct(0); },
          click: function(s, e) {
            const sl = e.target.closest('.swiper-slide');
            if(sl) selectProduct(parseInt(sl.getAttribute('data-real-index')));
          }
        }
      });
    }

    if (document.readyState === 'complete') {
      init();
    } else {
      window.addEventListener('load', init);
      document.addEventListener('shopify:section:load', init);
    }
  })();
</script>

{% schema %}
{
  "name": "Feature Coll Slider",
  "tag": "section",
  "class": "section feature-collection-slider",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEESON LATEST ARRIVALS" },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explore our carefully curated collection of spectacles and sunglasses.</p>"
    },
    { "type": "product_list", "id": "product_list", "label": "Products" },
    {
      "type": "select",
      "id": "indicator_style",
      "label": "Indicator Style",
      "options": [
        { "value": "top", "label": "Option 1: 25px Top" },
        { "value": "bottom", "label": "Option 2: Full Bottom" }
      ],
      "default": "bottom"
    },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#F2F2F2" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "Feature Coll Slider" }]
}
{% endschema %}
