<!-- Link Swiper's CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .feat-coll-slider {
    background-color: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
    color: #000;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    padding: 80px 0;
  }

  .feat-coll-content-wrapper {
    display: flex;
    position: relative;
    width: 100%;
    gap: 40px;
    align-items: stretch; /* Crucial for matching height */
  }

  /* Left Column: Info + Glasses + Thumbs */
  .feat-coll-left-col {
    width: 38%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 20;
    min-height: 600px; /* Base height */
  }

  .feat-coll-info-card-stationary {
    width: 100%;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .feat-coll-info-card-stationary.is-changing {
    opacity: 0;
    transform: translateY(10px);
  }

  .feat-coll-info-card-stationary h3 {
    color: #000;
    margin: 0 0 10px;
    font-family: var(--font-card-title-family);
    font-size: 32px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -1px;
    text-transform: uppercase;
  }

  .feat-coll-info-card-stationary .price {
    font-size: 24px;
    font-weight: 400;
    color: #666;
    margin-bottom: 2rem;
    font-family: var(--font-heading-family);
  }

  .feat-coll-info-card-stationary .product-img-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 20px 0;
  }

  .feat-coll-info-card-stationary .product-img-wrap img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }

  /* Right Column: Lifestyle Slider with Peek */
  .feat-coll-right-col {
    width: 62%;
    position: relative;
    overflow: hidden; /* Clip everything outside section width */
  }

  .lifestyle-swiper {
    width: 100% !important;
    height: 100% !important;
    overflow: visible !important; /* Allow the PEER effect */
  }

  .lifestyle-swiper .swiper-slide {
    height: 100%;
    transition: opacity 0.5s ease;
    opacity: 0.1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .lifestyle-swiper .swiper-slide-active {
    opacity: 1;
  }

  .lifestyle-swiper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Queue Thumbnails */
  .thumb-queue-wrap {
    width: 100%;
    margin-top: auto;
    padding: 20px 0;
  }

  .thumb-queue {
    display: flex;
    gap: 12px;
    width: 100%;
    flex-wrap: wrap; /* Fallback */
    transition: all 0.4s ease;
  }

  .thumb-item {
    width: 82px;
    height: 110px;
    flex-shrink: 0;
    cursor: pointer;
    filter: grayscale(100%);
    opacity: 1;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* The Transfer Gap */
  .thumb-item.is-active {
    opacity: 0 !important;
    pointer-events: none;
    }
    .lifestyle-swiper .swiper-slide {
      height: 400px;
      min-height: 400px;
    }
  }

  @media screen and (max-width: 989px) {
    .feat-coll-lifestyle-slider-wrap {
      width: 70%;
    }
    .feat-coll-info-card-stationary {
      width: 30%;
    }
  }

  @media screen and (max-width: 749px) {
    .feat-coll-content-wrapper {
      flex-direction: column;
    }
    .feat-coll-info-card-stationary,
    .feat-coll-lifestyle-slider-wrap {
      width: 100%;
      padding-right: 0;
    }
    .lifestyle-swiper .swiper-slide {
      height: 400px;
      min-height: 400px;
    }
  }
{%- endstyle -%}

<div class="feat-coll-slider section-{{ section.id }}-padding">
  <div class="page-width">
    <!-- Header stays at the top -->
    <div class="feat-coll-header">
      <h2 class="h1">{{ section.settings.heading }}</h2>
      <div class="description rte">{{ section.settings.description }}</div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="link underlined-link">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- Middle: Stationary Content + Lifestyle Slider -->
    <div class="feat-coll-content-wrapper">
      <!-- Left Column: Info + Glasses + Thumbnails -->
      <div class="feat-coll-left-col">
        <div class="feat-coll-info-card-stationary" id="FeatCollInfo-{{ section.id | replace: '-', '_' }}">
          <div class="product-info-row">
            <div class="title-price-wrap">
              <a href="#" class="product-title-link full-unstyled-link"><h3></h3></a>
              <p class="price"></p>
            </div>
            <button class="bookmark-btn" aria-label="Bookmark product">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
              </svg>
            </button>
          </div>
          <div class="product-img-wrap">
            <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" width="400" height="225" alt="Product" />
          </div>
        </div>

        <!-- Thumbnail Queue (Part of Left Column) -->
        <div class="thumb-queue-wrap">
          <div class="thumb-queue" id="ThumbQueue-{{ section.id | replace: '-', '_' }}">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product == blank -%}{%- continue -%}{%- endif -%}
              
              {%- assign thumb_person_img = block.settings.image | default: product.media[1] | default: product.featured_image -%}

              <div class="thumb-item" data-index="{{ forloop.index0 }}">
                {%- if thumb_person_img != blank -%}
                  {{ thumb_person_img | image_url: width: 200 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Right Column: Lifestyle Slider -->
      <div class="feat-coll-right-col">
        <div class="lifestyle-swiper" id="LifestyleSwiper-{{ section.id | replace: '-', '_' }}">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product == blank -%}{%- continue -%}{%- endif -%}
              
              {%- assign person_img = block.settings.image | default: product.media[1] | default: product.featured_image -%}
              {%- assign glasses_img = product.featured_image | default: product.media[0] -%}

              <div class="swiper-slide" 
                data-title="{{ product.title | escape }}"
                data-price="{{ product.price | money | escape }}"
                data-url="{{ product.url }}"
                data-glasses-img="{{ glasses_img | image_url: width: 600 }}"
              >
                {%- if person_img != blank -%}
                  {{ person_img | image_url: width: 1400 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Swiper JS CDN -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperId = '{{ section.id | replace: "-", "_" }}';
    const infoCard = document.getElementById('FeatCollInfo-' + swiperId);
    const thumbQueue = document.getElementById('ThumbQueue-' + swiperId);
    
    function updateInfo(slide) {
      if (!slide || !infoCard) return;
      const title = slide.getAttribute('data-title');
      const price = slide.getAttribute('data-price');
      const url = slide.getAttribute('data-url');
      const glassesImg = slide.getAttribute('data-glasses-img');

      infoCard.classList.add('is-changing');
      setTimeout(() => {
        infoCard.querySelector('h3').textContent = title || '';
        infoCard.querySelector('.price').innerHTML = price || '';
        infoCard.querySelectorAll('a').forEach(a => a.href = url || '#');
        infoCard.querySelector('.product-img-wrap img').src = glassesImg || '';
        infoCard.classList.remove('is-changing');
      }, 300);
    }

    const lifestyleSwiper = new Swiper('#LifestyleSwiper-' + swiperId, {
      slidesPerView: 1.15,
      centeredSlides: false,
      spaceBetween: 25,
      loop: false,
      speed: 800,
      grabCursor: true,
      on: {
        init: function() {
          updateUI(0);
        },
        slideChange: function() {
          updateUI(this.activeIndex);
        }
      }
    });

    function updateUI(activeIndex) {
      console.log('UPDATING UI for Index:', activeIndex);
      const slides = lifestyleSwiper.slides;
      if (!slides[activeIndex]) return;

      updateInfo(slides[activeIndex]);

      // Manage Thumbnail Queue
      const items = thumbQueue.querySelectorAll('.thumb-item');
      items.forEach(item => {
        const itemIdx = parseInt(item.getAttribute('data-index'));
        if (itemIdx === activeIndex) {
          item.classList.add('is-active');
          item.style.order = "99";
          console.log('Pinned item', itemIdx);
        } else {
          item.classList.remove('is-active');
          item.style.order = itemIdx.toString(); // Keep original order for others
        }
      });
    }

    // Handle Thumbnail Clicks
    thumbQueue.addEventListener('click', function(e) {
      const item = e.target.closest('.thumb-item');
      if (item) {
        const index = parseInt(item.getAttribute('data-index'));
        lifestyleSwiper.slideTo(index);
      }
    });
  });
</script>

{% schema %}
{
  "name": "Feature Coll Slider",
  "tag": "section",
  "class": "section feature-collection-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SEESON LATEST ARRIVALS"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Take your time exploring our carefully curated collection, where you'll find an array of spectacles and sunglasses...</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F2F2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product_slide",
      "name": "Product Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle Image (Large View)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Coll Slider",
      "blocks": [
        { "type": "product_slide" },
        { "type": "product_slide" },
        { "type": "product_slide" }
      ]
    }
  ]
}
{% endschema %}
