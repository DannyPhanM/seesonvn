{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'section-image-carousel.css' | asset_url | stylesheet_tag }}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

<div class="page-width">
  <slideshow-component
    class="slider-mobile-gutter image-carousel-section"
    role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
>
  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__controls slider-buttons no-js-hidden">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
              </svg>
            </span>
      </button>
      {%- if section.settings.show_dots -%}
        <div class="slider-counter slider-counter--dots">
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="dot"></span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
              </svg>
            </span>
      </button>
    </div>
  {%- endif -%}

  <div
    class="slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- for block in section.blocks -%}
      <div
        class="slideshow__slide grid__item grid--1-col slider__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        tabindex="-1"
      >
        <div class="image-carousel-item">
          {%- if block.settings.link_image and block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="image-carousel-link-overlay"></a>
          {%- endif -%}
          
          <div class="slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %}">
            {%- if block.settings.image -%}
              {%- liquid
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                assign sizes = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              -%}
              <picture>
                {%- if block.settings.mobile_image -%}
                  <source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 1500 }}" sizes="100vw">
                {%- endif -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                }}
              </picture>
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="image-carousel-content-container">
    <div class="image-carousel-content {{ section.settings.text_alignment }}">
      <div class="image-carousel-text-overlay">
        {%- if section.settings.subheading != blank -%}
          <p class="image-carousel-subheading h4">{{ section.settings.subheading }}</p>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="image-carousel-heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-carousel-description rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <div class="image-carousel-buttons">
          {%- if section.settings.button_1_label != blank -%}
            <a
              href="{{ section.settings.button_1_link | default: '#' }}"
              class=" button--{{ section.settings.button_1_style }}"
            >
              {{ section.settings.button_1_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_2_label != blank -%}
            <a
              href="{{ section.settings.button_2_link | default: '#' }}"
              class=" button--{{ section.settings.button_2_style }}"
            >
              {{ section.settings.button_2_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_3_label != blank -%}
            <a
              href="{{ section.settings.button_3_link | default: '#' }}"
              class=" button--{{ section.settings.button_3_style }}"
            >
              {{ section.settings.button_3_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</slideshow-component>
</div>

{% schema %}
{
  "name": "Image Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "options": [
        { "value": "adapt_image", "label": "Adapt to first image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full_screen", "label": "Full screen" }
      ],
      "default": "medium",
      "label": "Slider height"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Content Box"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "NEW COLLECTION"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Exquisite Designs"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Discover our latest collection featuring handcrafted details and premium materials.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left-top", "label": "Left Top" },
        { "value": "left-center", "label": "Left Middle" },
        { "value": "left-bottom", "label": "Left Bottom" },
        { "value": "center-top", "label": "Center Top" },
        { "value": "center-center", "label": "Center Middle" },
        { "value": "center-bottom", "label": "Center Bottom" },
        { "value": "right-top", "label": "Right Top" },
        { "value": "right-center", "label": "Right Middle" },
        { "value": "right-bottom", "label": "Right Bottom" }
      ],
      "default": "left-top",
      "label": "Content alignment"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "primary",
      "label": "Button 1 Style"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "secondary",
      "label": "Button 2 Style"
    },
    {
      "type": "header",
      "content": "Button 3"
    },
    {
      "type": "text",
      "id": "button_3_label",
      "label": "Button 3 label"
    },
    {
      "type": "url",
      "id": "button_3_link",
      "label": "Button 3 link"
    },
    {
      "type": "select",
      "id": "button_3_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "outline",
      "label": "Button 3 Style"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (optional)"
        },
        {
          "type": "checkbox",
          "id": "link_image",
          "label": "Enable Link on Image",
          "default": false
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
