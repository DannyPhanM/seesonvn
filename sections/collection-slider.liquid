<!-- Link Swiper's CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .coll-list-slider {
    background-color: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
    color: #000;
  }

  .coll-list-flex {
    display: flex;
    align-items: stretch;
  }

  /* LEFT: 45% */
  .coll-list-left {
    width: 45%;
    padding-right: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 30px;
    box-sizing: border-box;
  }

  .coll-list-info h2 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 10px;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
  }
  .coll-list-info .description {
    font-size: 16px;
    color: #666;
    margin: 0 0 20px;
    line-height: 1.5;
  }
  .coll-list-info .cta-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-transform: uppercase;
    color: #000;
  }

  /* THUMB SLIDER (Master) */
  .coll-list-thumbs-wrap {
    margin-top: auto;
    width: 100%;
    overflow: hidden;
    padding: 10px 0;
  }
  .coll-thumb-swiper .swiper-slide {
    height: 120px;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .coll-thumb-swiper .swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Highlight based on our custom class */
  .coll-thumb-swiper .swiper-slide.show-item {
    box-shadow: inset 0 0 0 3px #F2C94C;
  }

  /* RIGHT: 55% */
  .coll-list-right {
    width: 55%;
    height: 650px;
    background: #f7f7f7;
    position: relative;
    overflow: hidden;
  }
  .coll-master-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.5s ease;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .coll-list-flex { flex-direction: column; }
    .coll-list-left, .coll-list-right { width: 100%; padding: 0 15px; }
    .coll-list-right { height: 400px; order: 1; margin-bottom: 20px; }
    .coll-list-left { order: 2; gap: 20px; }
    .coll-list-info { text-align: center; }
  }
{%- endstyle -%}

{%- assign collection_list = section.settings.collection_list -%}
{%- assign total = collection_list.count | default: 0 -%}

<div class="coll-list-slider section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if total > 0 -%}
      <div class="coll-list-flex">
        <!-- LEFT Column -->
        <div class="coll-list-left">
          <div class="coll-list-info" id="ClInfo-{{ section.id | replace: '-', '_' }}">
            <h2>&nbsp;</h2>
            <div class="description">&nbsp;</div>
            <a href="#" class="cta-link">DISCOVER THE STORY</a>
          </div>

          <div class="coll-list-thumbs-wrap">
            <div class="swiper coll-thumb-swiper" id="ClMaster-{{ section.id | replace: '-', '_' }}">
              <div class="swiper-wrapper">
                {%- for collection in collection_list -%}
                  {%- assign main_img = collection.featured_image | default: collection.products.first.featured_image -%}

                  <div class="swiper-slide" 
                    data-real-index="{{ forloop.index0 }}"
                    data-title="{{ collection.title | escape }}"
                    data-description="{{ collection.description | strip_html | truncate: 160 | escape }}"
                    data-url="{{ collection.url }}"
                    data-img="{{ main_img | image_url: width: 1500 }}"
                  >
                    {%- if main_img != blank -%}
                      {{ main_img | image_url: width: 300 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT Column -->
        <div class="coll-list-right" id="ClRight-{{ section.id | replace: '-', '_' }}">
          <img class="coll-master-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Collection View" width="1200" height="800" loading="lazy" />
        </div>
      </div>
    {%- else -%}
      <div class="center">Please select collections in the section settings.</div>
    {%- endif -%}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
(function(){
  function init(){
    const sid = '{{ section.id | replace: "-", "_" }}';
    const mEl = document.getElementById('ClMaster-'+sid);
    const iEl = document.getElementById('ClInfo-'+sid);
    const rEl = document.getElementById('ClRight-'+sid);
    
    if(!mEl) return;

    function selectCollection(ri) {
      if (ri === undefined || ri === null) return;
      
      // 1. Manage Classes
      mEl.querySelectorAll('.swiper-slide').forEach(sl => sl.classList.remove('show-item'));
      const activeSlide = mEl.querySelector('.swiper-slide[data-real-index="' + ri + '"]');
      if (activeSlide) activeSlide.classList.add('show-item');

      if (!activeSlide) return;

      const title = activeSlide.getAttribute('data-title');
      const desc = activeSlide.getAttribute('data-description');
      const url = activeSlide.getAttribute('data-url');
      const img = activeSlide.getAttribute('data-img');

      // Update Info
      if(iEl) {
        const h2 = iEl.querySelector('h2');
        const dDiv = iEl.querySelector('.description');
        const cta = iEl.querySelector('.cta-link');
        if(h2) h2.textContent = title || '';
        if(dDiv) dDiv.textContent = desc || '';
        if(cta) cta.href = url || '#';
      }

      // Update Large Image (Right)
      const rImg = rEl.querySelector('img');
      if(rImg && img && rImg.src !== img) {
        rImg.style.opacity = '0';
        setTimeout(() => { 
          rImg.src = img; 
          rImg.onload = () => rImg.style.opacity = '1';
        }, 150);
      }
    }

    var swiper = new Swiper(mEl, {
      slidesPerView: 4,
      spaceBetween: 15,
      loop: false,
      grabCursor: true,
      slideToClickedSlide: true,
      watchSlidesProgress: true,
      breakpoints: {
        320: { slidesPerView: 2.5 },
        750: { slidesPerView: 4 },
        1200: { slidesPerView: 5 }
      },
      on: {
        init: function() {
          selectCollection(0);
        },
        click: function(s, e) {
          const slide = e.target.closest('.swiper-slide');
          if (slide) {
            const idx = parseInt(slide.getAttribute('data-real-index'));
            if (!isNaN(idx)) {
              selectCollection(idx);
            }
          }
        },
        slideChange: function() {
          if (this.activeIndex !== undefined) {
             const currentSelected = mEl.querySelector('.swiper-slide.show-item');
             const selIdx = currentSelected ? parseInt(currentSelected.getAttribute('data-real-index')) : -1;
             
             const spv = Math.floor(this.params.slidesPerView || 1);
             if (selIdx < this.activeIndex || selIdx >= (this.activeIndex + spv)) {
               selectCollection(this.activeIndex);
             }
          }
        }
      }
    });

    setTimeout(() => {
      if (swiper) selectCollection(0);
    }, 400);
  }

  document.addEventListener('DOMContentLoaded', init);
  if(window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', init);
  }
})();
</script>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "section collection-slider-section",
  "settings": [
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F2F2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Collection Slider"
    }
  ]
}
{% endschema %}
